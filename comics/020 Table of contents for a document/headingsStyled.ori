(outline) => Tree.indent`
  <ul style="list-style: none; margin: 0;">
    ${ Tree.map(outline, (content, heading) =>
      heading === "_text"
        ? ""
        : Tree.indent`
          <li>
            <a href="#${ Origami.slug(heading) }">${ heading }</a>
          </li>
          ${ typeof content === "object" ? headingsStyled.ori(content) : "" }
        `
    ) }
  </ul>
`
