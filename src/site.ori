// Transform all the content documents into HTML pages
Tree.mapExtension(content, {
  deep: true
  extension: ".md→.html"
  value: transform.ori
})

// The top-level structure of the site
→ (pages) => {
  // Static files
  ...Tree.deepMerge(
    client/
    {
      styles: {
        comic.css = Tree.deepText(./comics/styles/)
      }
    }
  )
  
  // Comics
  comics/ = comics/comics.ori/

  // For LLMs
  llms.txt = templates/llms.ori.md()

  // Folder of search indexes and resources
  pagefind/ = package:@weborigami/pagefind(pages)

  // All generated pages
  ...pages

  // Used by Netlify
  _redirects

  // Code samples
  samples/
}
